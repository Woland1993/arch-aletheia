# Force LF line endings on all text files — these scripts run on Linux.
# Without this, Git on Windows (autocrlf=true) rewrites scripts to CRLF,
# and bash on Arch fails with "No such file or directory" because of
# the trailing \r on sourced paths.

*           text=auto eol=lf

# Be explicit for the files we definitely need as LF
*.sh        text eol=lf
*.bash      text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.lua       text eol=lf
*.py        text eol=lf
*.rb        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.rules     text eol=lf
*.desktop   text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.qml       text eol=lf

# All files under bin/ and migrations/ are shell scripts without extensions
bin/*           text eol=lf
migrations/*    text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
