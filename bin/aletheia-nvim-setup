#!/bin/bash
# Setup Aletheia's Neovim configuration from the embedded default/nvim bundle.
# Replaces the former `omarchy-nvim-setup` that was shipped by omarchy-nvim.

set -euo pipefail

SRC_DIR="$HOME/.local/share/aletheia/default/nvim"
CONFIG_DIR="${HOME}/.config/nvim"
DATA_DIR="${HOME}/.local/share/nvim"
STATE_DIR="${HOME}/.local/state/nvim"
CACHE_DIR="${HOME}/.cache/nvim"

if [[ ! -d "$SRC_DIR" ]]; then
  echo "Error: Aletheia nvim config not found at $SRC_DIR"
  exit 1
fi

# Warn if an existing nvim config is present
if [[ -d "$CONFIG_DIR" ]]; then
  if command -v gum >/dev/null 2>&1; then
    if ! gum confirm "$(echo -e "Neovim configuration already exists at $CONFIG_DIR.\nThis will create a backup and overwrite it. Continue?")"; then
      echo "Setup cancelled."
      exit 0
    fi
  fi
  BACKUP_DIR="${CONFIG_DIR}.backup.$(date +%Y%m%d-%H%M%S)"
  echo "Backing up existing config to $BACKUP_DIR"
  mv "$CONFIG_DIR" "$BACKUP_DIR"
fi

echo "Setting up Neovim configuration..."

# Clear previous state so lazy.nvim starts fresh
rm -rf "$DATA_DIR" "$CACHE_DIR" "$STATE_DIR"

mkdir -p "$(dirname "$CONFIG_DIR")"
cp -r "$SRC_DIR" "$CONFIG_DIR"

# Trigger plugin sync so lazy.nvim installs everything on first run
if command -v nvim >/dev/null 2>&1; then
  echo "Syncing plugins (this may take a minute)..."
  nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
fi

echo -e "\033[32mNeovim configuration installed\033[0m"
