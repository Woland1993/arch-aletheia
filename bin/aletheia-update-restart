#!/bin/bash

echo

if [[ ! -d /usr/lib/modules/$(uname -r) ]]; then
  gum confirm "Linux kernel has been updated. Reboot?" && aletheia-system-reboot
elif [[ -f $HOME/.local/state/aletheia/reboot-required ]]; then
  gum confirm "Updates require reboot. Ready?" && aletheia-system-reboot
fi

running_hyprland=$(readlink /proc/$(pgrep -x Hyprland)/exe 2>/dev/null)
if [[ $running_hyprland == *"(deleted)"* ]]; then
  gum confirm "Hyprland has been updated. Reboot?" && aletheia-system-reboot
fi

for file in "$HOME"/.local/state/aletheia/restart-*-required; do
  if [[ -f $file ]]; then
    filename=$(basename "$file")
    service=$(echo "$filename" | sed 's/restart-\(.*\)-required/\1/')
    echo "Restarting $service"
    aletheia-state clear "$filename"
    aletheia-restart-"$service"
  fi
done
