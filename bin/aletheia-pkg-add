#!/bin/bash

# Add the named packages to the system if they're missing.
# Tries official repos first (pacman) and falls back to AUR (yay) for anything
# that pacman does not know about. Returns non-zero if any package failed.

set -u

if (( $# == 0 )); then
  exit 0
fi

# Filter to packages that are not already installed.
# We use `pacman -T` instead of `pacman -Q` so a package is considered
# satisfied if ANY installed package provides it (e.g. rustup provides rust,
# and vice-versa). This avoids trying to install conflicting alternatives.
needed=()
for pkg in "$@"; do
  if ! pacman -T "$pkg" &>/dev/null; then
    needed+=("$pkg")
  fi
done

if (( ${#needed[@]} == 0 )); then
  exit 0
fi

# Split into packages available from official repos vs AUR-only
pacman_pkgs=()
aur_pkgs=()
for pkg in "${needed[@]}"; do
  if pacman -Si "$pkg" &>/dev/null; then
    pacman_pkgs+=("$pkg")
  else
    aur_pkgs+=("$pkg")
  fi
done

# Work around a known rust/rustup conflict: some upstream packages declare
# `rust` as a dependency while others pull in `rustup` (which provides rust),
# and the two packages declare mutual conflict. Without intervention pacman
# prompts "Remove rust?" mid-transaction and fails under --noconfirm.
#
# We tell pacman to ASSUME `rustup` is already installed (via --assume-installed).
# Any package that depends on `rustup` will be considered satisfied and never
# added to the transaction. Packages that depend on `rust` (e.g. tree-sitter-cli)
# still pull in the real `rust` package from the official repo, which is what
# we actually want. The virtual rustup stays out of the transaction, so no
# conflict can occur.
PACMAN_ASSUME_ARGS=(
  --assume-installed=rustup=9999:1-1
)

if (( ${#pacman_pkgs[@]} > 0 )); then
  sudo pacman -S --noconfirm --needed "${PACMAN_ASSUME_ARGS[@]}" "${pacman_pkgs[@]}" || exit 1
fi

if (( ${#aur_pkgs[@]} > 0 )); then
  if ! command -v yay &>/dev/null; then
    echo -e "\033[31mError: yay is required for AUR packages but is not installed\033[0m" >&2
    echo "       Missing AUR packages: ${aur_pkgs[*]}" >&2
    exit 1
  fi
  yay -S --noconfirm --needed "${PACMAN_ASSUME_ARGS[@]}" "${aur_pkgs[@]}" || exit 1
fi

# Final verification (accept providers, same logic as above)
for pkg in "$@"; do
  if ! pacman -T "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
